{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "product-owner": {
      "description": "Main coordinator for feature development workflow",
      "mode": "primary",
      "permission": {
        "task": {
          "pm": "allow",
          "team-lead": "allow",
          "designer": "allow",
          "developer": "allow",
          "qa": "allow"
        }
      }
    },
    "pm": {
      "description": "Project Manager - coordinates workflow",
      "mode": "subagent",
      "permission": {
        "task": {
          "team-lead": "allow",
          "designer": "allow",
          "developer": "allow",
          "qa": "allow"
        }
      }
    },
    "team-lead": {
      "description": "Team Lead - planning and code review",
      "mode": "subagent",
      "permission": {
        "task": {
          "developer": "allow",
          "qa": "allow"
        }
      }
    },
    "developer": {
      "description": "Developer - implements code",
      "mode": "subagent"
    },
    "qa": {
      "description": "QA Engineer - runs tests",
      "mode": "subagent"
    },
    "designer": {
      "description": "Designer - UI/UX validation",
      "mode": "subagent"
    }
  }
}
